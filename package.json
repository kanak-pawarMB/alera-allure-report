{
  "name": "alerahealth-oneview",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:smoke": "npx playwright test --project=smoke",
    "report:html": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "rimraf allure-results allure-report",
    "test:phase2": "node qase/run-phase2.js",
    "test:adt-qase": "node qase/run-adt-alerts.js",
    "test:regression-qase": "node qase/run-regression-all.js",
    "test:smoke-qase": "node qase/run-smoke-all.js",
    "report:xlsx": "node qase/generate-xlsx-report.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "End-to-end test automation framework for the Alera ONEView healthcare application, built with Playwright.",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.10.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.2",
    "playwright-qase-reporter": "^2.1.7",
    "rimraf": "^6.1.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0"
  },
  "directories": {
    "test": "tests"
  }
}
